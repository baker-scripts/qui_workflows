{
  "_slug": "resume-incomplete",
  "name": "Resume Incomplete",
  "trackerPattern": "*",
  "trackerDomains": [
    "*"
  ],
  "conditions": {
    "schemaVersion": "1",
    "resume": {
      "enabled": true,
      "condition": {
        "operator": "AND",
        "conditions": [
          {
            "field": "PROGRESS",
            "operator": "LESS_THAN",
            "value": "1"
          },
          {
            "field": "STATE",
            "operator": "EQUAL",
            "value": "stopped"
          }
        ]
      }
    }
  },
  "intervalSeconds": 21600,
  "sortOrder": 2
}
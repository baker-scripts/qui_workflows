{
  "_slug": "delete-unregistered",
  "name": "Delete: unregistered",
  "trackerPattern": "*",
  "trackerDomains": [
    "*"
  ],
  "conditions": {
    "schemaVersion": "1",
    "delete": {
      "enabled": true,
      "mode": "deleteWithFilesPreserveCrossSeeds",
      "condition": {
        "operator": "AND",
        "conditions": [
          {
            "field": "IS_UNREGISTERED",
            "operator": "EQUAL",
            "value": "true"
          },
          {
            "field": "STATE",
            "operator": "NOT_EQUAL",
            "value": "tracker_down"
          },
          {
            "field": "ADDED_ON_AGE",
            "operator": "GREATER_THAN_OR_EQUAL",
            "value": "5400"
          }
        ]
      }
    }
  },
  "intervalSeconds": 900,
  "sortOrder": 7
}